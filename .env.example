# Copy this file to .env and fill in the values you need.

# Vector storage
CHROMA_PERSIST_DIR=chroma_data

# Embedding model (dense retrieval)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Chunking
MAX_TOKENS=300
OVERLAP_TOKENS=50

# Cross-encoder reranking (used when a request sets rerank=true)
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_OVERFETCH=4

# RAG /vector/ask endpoint - Google AI Studio (Gemini API).
# Get a free key at https://aistudio.google.com/apikey - no billing required
# for the free tier. Model names on the free tier change over time; check
# https://aistudio.google.com for current options if the default 404s.
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
